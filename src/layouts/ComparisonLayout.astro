---
import Layout from './Layout.astro';
import type { ComparisonRow, ComparisonProduct, ComparisonFaq } from '../data/comparisons';

interface Props {
  seoTitle: string;
  seoDescription: string;
  seoKeywords: string;
  h1: string;
  intro: string;
  ours: ComparisonProduct;
  theirs: ComparisonProduct;
  rows: ComparisonRow[];
  ourAdvantages: { title: string; desc: string }[];
  theirAdvantages: { title: string; desc: string }[];
  verdict: string;
  faq: ComparisonFaq[];
  ogImage?: string;
  publishDate?: string;
  updatedDate?: string;
}

const {
  seoTitle,
  seoDescription,
  seoKeywords,
  h1,
  intro,
  ours,
  theirs,
  rows,
  ourAdvantages,
  theirAdvantages,
  verdict,
  faq,
  ogImage,
  publishDate = '2026-03-28',
  updatedDate,
} = Astro.props;

const siteUrl = 'https://dev-tools-hub.xyz';
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalURL = `${siteUrl}${pathname}`;

// Structured data: FAQ
const faqSchema = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
} : null;

// Structured data: Article
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": h1,
  "description": seoDescription,
  "author": { "@type": "Organization", "name": "S-Hub", "url": siteUrl },
  "publisher": { "@type": "Organization", "name": "S-Hub", "url": siteUrl },
  "datePublished": publishDate,
  "dateModified": updatedDate || publishDate,
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
};

// Breadcrumb
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Extensions", "item": `${siteUrl}/#products` },
    { "@type": "ListItem", "position": 3, "name": `${ours.name} vs ${theirs.name}`, "item": canonicalURL },
  ]
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <div class="pt-24 pb-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="px-6 max-w-4xl mx-auto mb-6">
      <ol class="flex items-center gap-1.5 text-xs font-mono">
        <li><a href="/" class="text-zinc-400 hover:text-zinc-600 transition-colors">Home</a></li>
        <li class="text-zinc-300">/</li>
        <li><a href="/#products" class="text-zinc-400 hover:text-zinc-600 transition-colors">Extensions</a></li>
        <li class="text-zinc-300">/</li>
        <li><span class="text-zinc-600">Compare</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="px-6 py-8 max-w-4xl mx-auto text-center">
      <p class="font-mono text-[10px] text-sky-600 tracking-widest uppercase mb-4">Comparison</p>
      <h1 class="text-2xl md:text-3xl font-semibold text-zinc-900 mb-4 leading-tight">{h1}</h1>
      <p class="text-zinc-500 text-sm leading-relaxed max-w-2xl mx-auto">{intro}</p>
    </section>

    <!-- Product Cards Side by Side -->
    <section class="px-6 py-6 max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {/* Our product */}
        <div class="product-card p-5 border-sky-200 bg-sky-50/30 relative">
          <span class="absolute top-3 right-3 text-[9px] font-mono text-sky-600 bg-sky-100 px-2 py-0.5 rounded-full tracking-wider uppercase">S-Hub</span>
          <div class="flex items-center gap-3 mb-3">
            <img src={ours.icon} alt={ours.name} class="w-10 h-10 rounded-xl" />
            <div>
              <h2 class="text-sm font-semibold text-zinc-900">{ours.name}</h2>
              <p class="font-mono text-[10px] text-zinc-400">{ours.users} users</p>
            </div>
          </div>
          <div class="flex items-center gap-3 text-xs text-zinc-500">
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {ours.rating}
            </span>
            <span class="font-mono text-emerald-600">{ours.price}</span>
          </div>
          <div class="mt-3">
            <a href={ours.chromeUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-medium text-sky-600 hover:text-sky-700 transition-colors">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0 1 12 6.545h10.691A12 12 0 0 0 12 0zM1.931 5.47A11.943 11.943 0 0 0 0 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 0 1-6.865-2.29zm13.342 2.166a5.446 5.446 0 0 1 1.45 7.09l.002.001h-.002l-3.952 6.848a12.014 12.014 0 0 0 9.229-9.605zM12 16.364a4.364 4.364 0 1 1 0-8.728 4.364 4.364 0 0 1 0 8.728z"/></svg>
              Add to Chrome
            </a>
          </div>
        </div>

        {/* Competitor */}
        <div class="product-card p-5">
          <div class="flex items-center gap-3 mb-3 mt-5">
            <img src={theirs.icon} alt={theirs.name} class="w-10 h-10 rounded-xl" onerror="this.onerror=null;this.src='/ext-icons/compare/placeholder.svg'" />
            <div>
              <h2 class="text-sm font-semibold text-zinc-900">{theirs.name}</h2>
              <p class="font-mono text-[10px] text-zinc-400">{theirs.users} users</p>
            </div>
          </div>
          <div class="flex items-center gap-3 text-xs text-zinc-500">
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {theirs.rating}
            </span>
            <span class="font-mono">{theirs.price}</span>
          </div>
          {theirs.badge && (
            <p class="mt-2 text-[10px] font-mono text-zinc-400">{theirs.badge}</p>
          )}
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="px-6 py-8 max-w-4xl mx-auto">
      <h2 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-4">// feature comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-zinc-200">
              <th class="text-left py-3 px-3 font-mono text-[10px] text-zinc-400 tracking-wider uppercase w-[40%]">Feature</th>
              <th class="text-center py-3 px-3 font-mono text-[10px] text-sky-600 tracking-wider uppercase w-[30%]">{ours.name}</th>
              <th class="text-center py-3 px-3 font-mono text-[10px] text-zinc-400 tracking-wider uppercase w-[30%]">{theirs.name}</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr class={`border-b border-zinc-100 ${row.highlight ? 'bg-sky-50/40' : ''}`}>
                <td class="py-3 px-3 text-zinc-700 text-[13px]">{row.feature}</td>
                <td class="py-3 px-3 text-center text-[13px] text-zinc-600">{row.ours}</td>
                <td class="py-3 px-3 text-center text-[13px] text-zinc-500">{row.theirs}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Advantages: Ours -->
    <section class="px-6 py-8 max-w-4xl mx-auto">
      <h2 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-4">// why choose {ours.name}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {ourAdvantages.map((adv, idx) => (
          <div class="product-card p-4 border-sky-100 fade-in" style={`animation-delay: ${idx * 80}ms`}>
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-sky-500 rounded-full mt-1.5 flex-shrink-0"></div>
              <div>
                <h3 class="text-[13px] font-medium text-zinc-900 mb-0.5">{adv.title}</h3>
                <p class="text-zinc-500 text-xs leading-relaxed">{adv.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Advantages: Theirs (fair comparison) -->
    <section class="px-6 py-8 max-w-4xl mx-auto">
      <h2 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-4">// why choose {theirs.name}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {theirAdvantages.map((adv, idx) => (
          <div class="product-card p-4 fade-in" style={`animation-delay: ${idx * 80}ms`}>
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 bg-zinc-300 rounded-full mt-1.5 flex-shrink-0"></div>
              <div>
                <h3 class="text-[13px] font-medium text-zinc-900 mb-0.5">{adv.title}</h3>
                <p class="text-zinc-500 text-xs leading-relaxed">{adv.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Verdict -->
    <section class="px-6 py-8 max-w-4xl mx-auto">
      <h2 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-4">// verdict</h2>
      <div class="product-card p-6 border-sky-100 bg-sky-50/20">
        <p class="text-zinc-700 text-sm leading-relaxed">{verdict}</p>
      </div>
    </section>

    <!-- FAQ -->
    {faq.length > 0 && (
      <section class="px-6 py-8 max-w-4xl mx-auto">
        <h2 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-4">// faq</h2>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="product-card p-4 group">
              <summary class="flex items-center justify-between cursor-pointer text-[13px] font-medium text-zinc-900">
                <span>{item.question}</span>
                <svg class="w-4 h-4 text-zinc-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <p class="text-zinc-500 text-xs leading-relaxed mt-2">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="px-6 py-8 max-w-4xl mx-auto">
      <div class="product-card p-8 text-center border-sky-100">
        <h2 class="text-xl font-semibold text-zinc-900 mb-2">Ready to try {ours.name}?</h2>
        <p class="text-zinc-500 text-sm mb-6">Install {ours.name} for free and see how it compares.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={ours.chromeUrl} target="_blank" rel="noopener noreferrer" class="btn-primary flex items-center gap-2 text-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0 1 12 6.545h10.691A12 12 0 0 0 12 0zM1.931 5.47A11.943 11.943 0 0 0 0 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 0 1-6.865-2.29zm13.342 2.166a5.446 5.446 0 0 1 1.45 7.09l.002.001h-.002l-3.952 6.848a12.014 12.014 0 0 0 9.229-9.605zM12 16.364a4.364 4.364 0 1 1 0-8.728 4.364 4.364 0 0 1 0 8.728z"/></svg>
            Add to Chrome — Free
          </a>
          {ours.extensionPageUrl && (
            <a href={ours.extensionPageUrl} class="btn-secondary flex items-center gap-2 text-sm font-mono">
              Learn more →
            </a>
          )}
        </div>
      </div>
    </section>

    <!-- Related comparisons slot -->
    <slot />
  </div>
</Layout>
