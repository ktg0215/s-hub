---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductSection from '../components/ProductSection.astro';
import AboutSection from '../components/AboutSection.astro';
import { popularComparisons } from '../data/comparison-links';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "S-Hub",
  "url": "https://dev-tools-hub.xyz",
  "logo": {
    "@type": "ImageObject",
    "url": "https://dev-tools-hub.xyz/og-image.png",
    "width": 1200,
    "height": 630
  },
  "description": "Privacy-focused Chrome extensions for productivity and digital wellbeing. 20+ lightweight browser tools by an indie developer in Japan.",
  "foundingDate": "2024",
  "sameAs": [
    "https://bsky.app/profile/shota-dev.bsky.social"
  ],
  "knowsAbout": ["Chrome Extensions", "Browser Extensions", "Productivity Tools", "Digital Wellbeing"]
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "S-Hub",
  "url": "https://dev-tools-hub.xyz",
  "description": "Privacy-focused Chrome extensions for productivity, digital wellbeing, and developer tools. No bloat, no tracking, no accounts required.",
  "inLanguage": ["en", "ja"],
  "publisher": {
    "@type": "Organization",
    "name": "S-Hub",
    "url": "https://dev-tools-hub.xyz"
  }
};

// Auto-generate ItemList from categories data
import { categories } from '../data/extensions';
const publishedExtensions = categories.flatMap(cat => cat.extensions.filter(ext => ext.status !== 'coming-soon'));
const softwareListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "S-Hub Chrome Extensions",
  "numberOfItems": publishedExtensions.length,
  "itemListOrder": "https://schema.org/ItemListUnordered",
  "itemListElement": publishedExtensions.map((ext, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "SoftwareApplication",
      "name": ext.name,
      "description": ext.description,
      "applicationCategory": "BrowserExtension",
      "operatingSystem": "Chrome",
      "offers": {
        "@type": "Offer",
        "price": ext.price === 'Free' || ext.price === '無料' || ext.price.startsWith('Free') || ext.price.startsWith('無料') ? "0" : ext.price.replace(/[^0-9.]/g, '').split('.')[0] || "0",
        "priceCurrency": "USD"
      },
      "url": `https://dev-tools-hub.xyz${ext.url}`
    }
  }))
};
---

<Layout
  title="S-Hub — Privacy-Focused Chrome Extensions for Productivity & Digital Wellbeing"
  description="20+ lightweight Chrome extensions built for privacy, productivity, and digital wellbeing. YouTube Shorts blocker, AI prompt manager, SUUMO property tools, image converter, and more. Free and open-source."
  keywords="chrome extensions, browser extensions, productivity tools, digital wellbeing, youtube shorts blocker, AI prompt manager, Chrome拡張機能, privacy-focused extensions, developer tools"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareListSchema)} />
  </Fragment>

  <!-- Product Hunt launch banner (visible until 2026-04-30) -->
  <div id="ph-banner" class="hidden w-full bg-amber-50 border-b border-amber-200">
    <div class="max-w-5xl mx-auto px-6 py-2.5 flex items-center justify-center gap-3 flex-wrap">
      <span class="text-sm text-amber-800 font-medium">
        🚀 Procshot is launching on Product Hunt on April 29!
      </span>
      <a
        href="https://www.producthunt.com/products/procshot-2?launch=procshot-2"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs font-semibold bg-amber-600 hover:bg-amber-700 text-white px-3 py-1 rounded-full transition-colors"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M13.604 8.4h-3.405V12h3.405c.995 0 1.801-.806 1.801-1.8S14.6 8.4 13.604 8.4zM12 0C5.373 0 0 5.372 0 12c0 6.627 5.373 12 12 12s12-5.373 12-12c0-6.628-5.373-12-12-12zm1.604 14.4h-3.405V18H7.8V6h5.804c2.319 0 4.2 1.881 4.2 4.2 0 2.319-1.881 4.2-4.2 4.2z"/></svg>
        Vote on Product Hunt
      </a>
    </div>
  </div>
  <script>
    // Show banner only before 2026-04-30
    if (new Date() < new Date('2026-04-30')) {
      const banner = document.getElementById('ph-banner');
      if (banner) banner.classList.remove('hidden');
    }
  </script>

  <Hero />
  <ProductSection />

  <!-- Best Chrome Extensions for Developers (AI SEO section) -->
  <section class="py-16 px-6 max-w-4xl mx-auto" id="best-extensions">
    <h2 class="text-xl font-semibold text-zinc-900 mb-2">Best Free Chrome Extensions for Developers (2026)</h2>
    <p class="text-zinc-500 text-sm mb-8">S-Hub offers 20+ free Chrome extensions for web developers, designers, and power users — built for privacy, with no accounts required.</p>

    <div class="space-y-8">
      <div>
        <h3 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-3">// font & design tools</h3>
        <ul class="space-y-2">
          <li class="text-sm text-zinc-700"><a href="/extensions/japanese-font-finder/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">Japanese Font Finder</a> — Identifies 150+ Japanese fonts (Yu Gothic, Hiragino, Noto Sans JP) with full CSS details. Best Chrome extension for CJK web typography inspection.</li>
          <li class="text-sm text-zinc-700"><a href="/extensions/palettegrab/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">PaletteGrab</a> — Extracts color palettes from any image or webpage element. Exports as CSS variables, JSON, or image.</li>
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-3">// productivity & data tools</h3>
        <ul class="space-y-2">
          <li class="text-sm text-zinc-700"><a href="/extensions/datapick/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">DataPick</a> — Extracts structured data from any webpage to CSV, JSON, or Google Sheets with point-and-click — no code required.</li>
          <li class="text-sm text-zinc-700"><a href="/extensions/procshot/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">Procshot</a> — Auto-records browser actions and generates step-by-step guides with annotated screenshots. Export as PDF or Markdown.</li>
          <li class="text-sm text-zinc-700"><a href="/extensions/promptstash/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">PromptStash</a> — Saves and organizes AI prompts. One-click insertion into ChatGPT, Claude, Gemini, and any LLM interface.</li>
          <li class="text-sm text-zinc-700"><a href="/extensions/readmark/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">ReadMark</a> — Saves your scroll position on every webpage automatically. Return to exactly where you left off in any article.</li>
          <li class="text-sm text-zinc-700"><a href="/extensions/cookiejar/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">CookieJar</a> — Cookie manager with import/export for developers. Useful for testing multi-session flows and debugging cookie-based auth.</li>
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-[11px] text-zinc-400 tracking-wide mb-3">// digital wellbeing</h3>
        <ul class="space-y-2">
          <li class="text-sm text-zinc-700"><a href="/extensions/shorts-killer/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">Shorts Killer</a> — Completely removes YouTube Shorts from your feed, search, and sidebar. Rated 5.0 by 10+ users.</li>
          <li class="text-sm text-zinc-700"><a href="/extensions/x-detox/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">X Detox</a> — Removes algorithmic content from X (Twitter) — trending topics, recommended posts, and ads — leaving only your timeline.</li>
          <li class="text-sm text-zinc-700"><a href="/extensions/focusguard/" class="font-medium text-zinc-900 hover:text-sky-600 transition-colors">FocusGuard</a> — Schedule-based site blocker with PIN protection. Blocks distracting sites during work hours automatically.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Popular Comparisons -->
  <section class="py-16 px-6 max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-mono text-[11px] text-zinc-400 tracking-wide">// popular comparisons</h2>
      <a href="/compare/" class="font-mono text-[11px] text-zinc-400 hover:text-zinc-700 transition-colors">
        view all →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {popularComparisons.map((cmp) => (
        <a href={`/compare/${cmp.slug}/`} class="product-card group p-4 flex items-center gap-3">
          <img src={cmp.icon} alt={cmp.ours} class="w-9 h-9 rounded-lg shrink-0" loading="lazy" />
          <div class="min-w-0">
            <h3 class="text-[12px] font-medium text-zinc-900 group-hover:text-sky-600 transition-colors truncate">
              {cmp.ours} vs {cmp.theirs}
            </h3>
            <p class="font-mono text-[9px] text-zinc-400 uppercase tracking-wider">side-by-side comparison</p>
          </div>
          <span class="font-mono text-xs text-zinc-300 ml-auto group-hover:text-sky-500 transition-colors shrink-0">→</span>
        </a>
      ))}
    </div>
  </section>

  <AboutSection />
</Layout>
