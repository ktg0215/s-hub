---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductSection from '../components/ProductSection.astro';
import AboutSection from '../components/AboutSection.astro';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "S-Hub",
  "url": "https://dev-tools-hub.xyz",
  "logo": {
    "@type": "ImageObject",
    "url": "https://dev-tools-hub.xyz/og-image.png",
    "width": 1200,
    "height": 630
  },
  "description": "Privacy-focused Chrome extensions for productivity and digital wellbeing. 20+ lightweight browser tools by an indie developer in Japan.",
  "foundingDate": "2024",
  "sameAs": [
    "https://bsky.app/profile/shota-dev.bsky.social"
  ],
  "knowsAbout": ["Chrome Extensions", "Browser Extensions", "Productivity Tools", "Digital Wellbeing"]
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "S-Hub",
  "url": "https://dev-tools-hub.xyz",
  "description": "Privacy-focused Chrome extensions for productivity, digital wellbeing, and developer tools. No bloat, no tracking, no accounts required.",
  "inLanguage": ["en", "ja"],
  "publisher": {
    "@type": "Organization",
    "name": "S-Hub",
    "url": "https://dev-tools-hub.xyz"
  }
};

// Auto-generate ItemList from categories data
import { categories } from '../data/extensions';
const publishedExtensions = categories.flatMap(cat => cat.extensions.filter(ext => ext.status !== 'coming-soon'));
const softwareListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "S-Hub Chrome Extensions",
  "numberOfItems": publishedExtensions.length,
  "itemListOrder": "https://schema.org/ItemListUnordered",
  "itemListElement": publishedExtensions.map((ext, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "SoftwareApplication",
      "name": ext.name,
      "description": ext.description,
      "applicationCategory": "BrowserExtension",
      "operatingSystem": "Chrome",
      "offers": {
        "@type": "Offer",
        "price": ext.price === 'Free' || ext.price === '無料' || ext.price.startsWith('Free') || ext.price.startsWith('無料') ? "0" : ext.price.replace(/[^0-9.]/g, '').split('.')[0] || "0",
        "priceCurrency": "USD"
      },
      "url": `https://dev-tools-hub.xyz${ext.url}`
    }
  }))
};
---

<Layout
  title="S-Hub — Privacy-Focused Chrome Extensions for Productivity & Digital Wellbeing"
  description="20+ lightweight Chrome extensions built for privacy, productivity, and digital wellbeing. YouTube Shorts blocker, AI prompt manager, SUUMO property tools, image converter, and more. Free and open-source."
  keywords="chrome extensions, browser extensions, productivity tools, digital wellbeing, youtube shorts blocker, AI prompt manager, Chrome拡張機能, privacy-focused extensions, developer tools"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareListSchema)} />
  </Fragment>
  <Hero />
  <ProductSection />
  <AboutSection />
</Layout>
