---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// /blog — post list (newest first, drafts excluded).
const posts = (await getCollection('blog', ({ data }) => data.draft !== true)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title="Blog — S-Hub"
  description="S-Hub の Chrome 拡張機能づくりの裏側、使い方のコツ、アップデート情報。"
  lang="ja"
>
  <div class="container mx-auto px-6 py-24 max-w-3xl min-h-[60vh]">
    <a href="/" class="inline-flex items-center gap-1 text-xs font-mono text-zinc-400 hover:text-sky-500 transition-colors mb-8">
      &larr; back
    </a>

    <h1 class="font-mono text-[11px] text-zinc-400 mb-6 tracking-wide">// blog</h1>

    {posts.length === 0 ? (
      <p class="text-sm text-zinc-500">記事はまだありません。</p>
    ) : (
      <div class="flex flex-col gap-3">
        {posts.map((post, idx) => (
          <a
            href={`/blog/${post.id}/`}
            class="product-card group p-6 fade-in"
            style={`animation-delay: ${idx * 60}ms`}
          >
            <time datetime={post.data.date.toISOString()} class="font-mono text-[11px] text-zinc-400">
              {dateFmt.format(post.data.date)}
            </time>
            <h2 class="mt-1.5 text-base font-semibold text-zinc-900 group-hover:text-sky-600 transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-1.5 text-sm text-zinc-600 leading-relaxed line-clamp-2">
              {post.data.description}
            </p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {post.data.tags.map((tag) => (
                  <span class="font-mono text-[10px] text-zinc-400 rounded border border-zinc-200 px-1.5 py-0.5">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
