---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// /blog/{slug} — render a single post body. Static paths from the collection.
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// og-guard (ADR 2026-07-08-image-cadence): 記事に image があれば OG に使い、無ければ
// Layout のデフォルト OG に fallback（build は落とさない）＋ build ログに warn。
if (!post.data.image) {
  // console.log (stdout) を使う: Astro build のビルドログ(stdout)に確実に出し、CI で
  // 画像欠落を検知可能にする（console.warn は stderr でCI stdout capture に載らず monitoring 目的を満たさない）。
  console.log(`[og-guard] blog post "${post.id}" has no image - falling back to default OG`);
}

const dateFmt = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${post.data.title} — S-Hub Blog`}
  description={post.data.description}
  ogImage={post.data.image}
  lang="ja"
  ogType="article"
>
  <div class="container mx-auto px-6 py-24 max-w-2xl min-h-[60vh]">
    <a href="/blog/" class="inline-flex items-center gap-1 text-xs font-mono text-zinc-400 hover:text-sky-500 transition-colors mb-8">
      &larr; blog
    </a>

    <article>
      <header class="mb-8">
        <time datetime={post.data.date.toISOString()} class="font-mono text-[11px] text-zinc-400">
          {dateFmt.format(post.data.date)}
        </time>
        <h1 class="mt-2 text-2xl font-semibold text-zinc-900 tracking-tight">
          {post.data.title}
        </h1>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <span class="font-mono text-[10px] text-zinc-400 rounded border border-zinc-200 px-1.5 py-0.5">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose-blog text-sm text-zinc-700 leading-relaxed">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
  .prose-blog :global(h2) {
    font-size: 1.05rem;
    font-weight: 600;
    color: #18181b;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-blog :global(p) {
    margin-bottom: 1rem;
  }
  .prose-blog :global(ul) {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }
  .prose-blog :global(li) {
    margin-bottom: 0.35rem;
  }
  .prose-blog :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
