  seoDescription="Record reproduction steps as you discover bugs — Procshot auto-captures annotated screenshots at each click. Export as Markdown and paste into GitHub, Linear, or Jira."
  seoKeywords="how to create bug report with screenshots, bug report chrome extension, screenshot bug report tool, reproduce bug documentation, qa screenshot tool"
  h1="How to Create Bug Reports with Screenshots"
  tldr={tldr}
  whyMatters={whyMatters}
  steps={steps}
  useCases={useCases}
  faq={faq}
  tips={tips}
  pitfalls={pitfalls}
  relatedTools={relatedTools}
  publishDate="2026-04-11"
