---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "TabPinner",
  subtitle: "Save & Restore Tab Sessions",
  tagline: "Pin your tabs into named groups and restore them any time. Chrome's native pin doesn't save URLs — TabPinner does.",
  price: "Free / Pro $2.99/mo",
  status: "Available",
  chromeUrl: "",
  edgeUrl: "",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/TabPinner.png",
  rating: 0,
  reviewCount: 0,
};

const overview = "Chrome's built-in pinned tabs disappear when you close the window. TabPinner solves this by saving your tab URLs into named groups — 'Project A', 'Morning Routine', 'Research' — and letting you restore them with one click at any time. Pro users get unlimited groups and automatic restoration on every browser startup.";

const features = [
  { title: "Named Groups", desc: "Save all tabs in the current window as a named group. Give it a memorable name — 'Client Work', 'Study Session', or any label that fits your workflow." },
  { title: "One-Click Restore", desc: "Click 'Open all' on any group to open every saved tab in the background. Your current tabs stay intact." },
  { title: "Auto-Restore on Startup (Pro)", desc: "Mark any group for auto-restore and TabPinner opens those tabs automatically every time you launch Chrome." },
  { title: "Session-Persistent", desc: "Unlike Chrome's native pinned tabs, TabPinner groups survive window closes, crashes, and browser updates." },
];

const targetUsers = [
  "Developers who switch between multiple project contexts",
  "Researchers who return to the same set of reference tabs",
  "Anyone who loses their tabs when Chrome crashes",
  "Power users with complex multi-session workflows",
];

const screenshots: string[] = [];

const relatedProducts = [
  { name: "PasswordStrength", category: "Wellbeing", link: "/extensions/passwordstrength/", icon: "/ext-icons/PasswordStrength.png" },
  { name: "BookmarkHub", category: "Productivity", link: "/extensions/bookmarkhub/", icon: "/ext-icons/BookmarkHub.png" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: extension.name,
  description: extension.tagline,
  applicationCategory: "BrowserApplication",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "2.99", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  seoTitle="TabPinner — Save & Restore Tab Sessions for Chrome"
  seoDescription="Pin tab sessions as named groups and restore them anytime. Auto-restore on startup with Pro. Free up to 10 pins. Chrome extension."
  seoKeywords="tab sessions, tab manager, save tabs, restore tabs, chrome extension, productivity, session manager"
/>
