---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "DataPick",
  subtitle: "No-code Web Scraping",
  tagline: "Extract data from any website without writing a single line of code",
  price: "$19 One-time",
  status: "Available",
  chromeUrl: "https://chromewebstore.google.com/detail/epoehadeccangbpjldlbkapnakndbpkf",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/datapick.webp",
  rating: 0,
  reviewCount: 0,
  userCount: 83,
};

const overview = "Tired of copying and pasting data from websites one by one? DataPick lets you scrape any website with just a few clicks. Simply click on the data you want, and DataPick automatically finds all similar elements on the page. Export your data to CSV, Excel, or Google Sheets instantly. No coding skills required.";

const features = [
  { title: "Point & Click Selection", desc: "Simply click on the data you want to extract" },
  { title: "Smart Element Detection", desc: "Automatically finds all similar items on the page" },
  { title: "Multiple Export Options", desc: "CSV, Excel, JSON, and Google Sheets" },
  { title: "Live Data Preview", desc: "See your extracted data in real-time before exporting" },
  { title: "Save Scraping Recipes", desc: "Save your setup and reuse it anytime" },
  { title: "Multi-page Scraping (Pro)", desc: "Follow pagination automatically" },
  { title: "Duplicate Detection (Pro)", desc: "Automatically skip duplicate rows" },
];

const targetUsers = [
  "E-commerce sellers tracking competitor prices",
  "Sales teams building lead lists from directories",
  "Recruiters extracting candidate information",
  "Researchers gathering data for analysis",
];

const screenshots = [
  "/screenshots/datapick/screenshot-01.png",
  "/screenshots/datapick/screenshot-02.png",
  "/screenshots/datapick/screenshot-03.png",
  "/screenshots/datapick/screenshot-04.png",
  "/screenshots/datapick/screenshot-05.png",
];

const relatedProducts = [
  { name: "DataBridge", category: "Productivity", link: "/extensions/databridge/", icon: "/ext-icons/databridge.webp" },
  { name: "Arbitra", category: "E-Commerce", link: "/extensions/arbitra/", icon: "/ext-icons/Arbitra.webp" },
  { name: "ReShapic", category: "Image Tools", link: "/extensions/reshapic/", icon: "/ext-icons/reshapic.png" },
];

const faqItems = [
  { question: "Do I need coding skills to use DataPick?", answer: "No. DataPick uses a point-and-click interface. Simply click on the data you want, and DataPick automatically finds all similar elements on the page." },
  { question: "What formats can I export to?", answer: "DataPick supports CSV, Excel (XLSX), JSON, and Google Sheets export." },
  { question: "Is DataPick a subscription?", answer: "No. DataPick is a one-time purchase of $19 with no recurring fees." },
  { question: "Can I scrape multiple pages automatically?", answer: "Yes, the Pro version includes multi-page scraping that automatically follows pagination links." },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "DataPick",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "19", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/datapick/",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/datapick/screenshot-01.png",
  featureList: "Point & Click Selection, Smart Element Detection, Multiple Export Options, Live Data Preview, Save Scraping Recipes, Multi-page Scraping, Duplicate Detection",
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="DataPick - No-Code Web Scraping Tool | Chrome Extension"
  seoDescription="Extract data from any website without coding. Point-and-click scraping with CSV, Excel, and Google Sheets export. Save scraping recipes and reuse them."
  seoKeywords="web scraping, data extraction, no-code scraper, csv export, chrome extension, google sheets export, scraping tool, web data"
  ctaTitle="Start Extracting Data"
  ctaDescription="Point, click, and export — web scraping made simple."
/>
