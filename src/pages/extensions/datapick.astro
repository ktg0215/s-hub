---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "DataPick",
  subtitle: "No-code Web Scraping with Sidebar UI",
  tagline: "Extract data from any website without writing a single line of code. Persistent sidebar panel, comparison table modal, and reusable scraping recipes.",
  price: "$19 One-time",
  status: "Available",
  chromeUrl: "https://chromewebstore.google.com/detail/epoehadeccangbpjldlbkapnakndbpkf",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/datapick.webp",
  rating: 0,
  reviewCount: 0,
  userCount: 83,
};

const overview = "Tired of copying and pasting data from websites one by one? DataPick v1.3.4 lets you scrape any website with just a few clicks. A persistent sidebar panel (340px, anchored to the right edge) stays open as you browse — click on the data you want, and DataPick automatically finds all similar elements on the page. The comparison table modal lets you review and clean extracted data before export. Save your selection setup as a named recipe and replay it on the same site any time. Export to CSV, Excel, JSON, or directly to Google Sheets. No coding skills required.";

const features = [
  { title: "Persistent Sidebar Panel", desc: "340px panel anchored to the right edge — stays open as you browse and navigate between pages" },
  { title: "Point & Click Selection", desc: "Click on one example item; DataPick detects all matching elements on the page automatically" },
  { title: "Comparison Table Modal", desc: "Review all extracted data in a full-screen modal table before export — clean, reorder, and deselect rows" },
  { title: "Save Scraping Recipes", desc: "Save your selection setup as a named recipe and replay it on the same site any time, no reconfiguration needed" },
  { title: "Multiple Export Options", desc: "CSV, Excel (XLSX), JSON, and direct Google Sheets export" },
  { title: "Live Data Preview", desc: "See your extracted data in real-time in the sidebar as you click" },
  { title: "Multi-page Scraping (Pro)", desc: "Follow pagination links automatically to collect data across all pages in a single session" },
  { title: "Duplicate Detection (Pro)", desc: "Automatically skip duplicate rows when scraping paginated or overlapping data" },
];

const targetUsers = [
  "E-commerce sellers tracking competitor prices",
  "Sales teams building lead lists from directories",
  "Recruiters extracting candidate information",
  "Researchers gathering data for analysis",
];

const screenshots = [
  "/screenshots/datapick/screenshot-01.png",
  "/screenshots/datapick/screenshot-02.png",
  "/screenshots/datapick/screenshot-03.png",
  "/screenshots/datapick/screenshot-04.png",
  "/screenshots/datapick/screenshot-05.png",
];

const relatedProducts = [
  { name: "DataBridge", category: "Productivity", link: "/extensions/databridge/", icon: "/ext-icons/databridge.webp" },
  { name: "Arbitra", category: "E-Commerce", link: "/extensions/arbitra/", icon: "/ext-icons/Arbitra.webp" },
  { name: "ReShapic", category: "Image Tools", link: "/extensions/reshapic/", icon: "/ext-icons/reshapic.png" },
];

const definition = "DataPick is a Chrome extension that extracts structured data from any webpage using a point-and-click interface — no code, no CSS selectors required. Click on one item in a repeating list (product, row, card), and DataPick automatically finds all similar elements and exports them as CSV, JSON, or directly to Google Sheets. It works with JavaScript-rendered pages including React and Vue apps.";

const howToSteps = [
  "Install DataPick from the Chrome Web Store.",
  "Navigate to the webpage containing the data you want to extract.",
  "Click the DataPick icon — a 340px sidebar panel opens on the right side of the page.",
  "Click on one example item in the list (a product, a row, a card) — DataPick detects all similar elements automatically.",
  "Open the comparison table modal to review, clean, and confirm your extracted rows.",
  "Click Export and choose CSV, JSON, Excel, or Google Sheets. Optionally save the setup as a recipe for next time.",
];

const faqItems = [
  { question: "Do I need coding skills to use DataPick?", answer: "No. DataPick uses a point-and-click interface. Click on the data you want, and DataPick automatically finds all similar elements on the page. No CSS selectors or programming required." },
  { question: "What types of data can I extract?", answer: "DataPick extracts text, links (URLs), prices, dates, and image URLs. It works on product listings, directories, search results, tables, and any structured webpage content including JavaScript-rendered pages." },
  { question: "What formats can I export to?", answer: "DataPick supports CSV (for Excel/Google Sheets), JSON (for developers), Excel (XLSX), and direct Google Sheets export. The free plan includes a 10-row preview; unlimited export requires DataPick Pro." },
  { question: "Is DataPick a subscription?", answer: "No. DataPick is a one-time purchase of $19 with no recurring fees." },
  { question: "Can I scrape multiple pages automatically?", answer: "Yes, the Pro version includes multi-page scraping that automatically follows pagination links, collecting data across all pages in a single session." },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "DataPick",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "19", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/datapick/",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/datapick/screenshot-01.png",
  featureList: "Sidebar Panel, Point & Click Selection, Comparison Table Modal, Save Scraping Recipes, Multiple Export Options, Live Data Preview, Multi-page Scraping, Duplicate Detection",
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  definition={definition}
  howToSteps={howToSteps}
  seoTitle="DataPick - No-Code Web Scraping Tool | Chrome Extension"
  seoDescription="Extract data from any website without coding. Persistent sidebar panel, comparison table modal, reusable scraping recipes. Export to CSV, Excel, or Google Sheets. $19 one-time."
  seoKeywords="web scraping, data extraction, no-code scraper, csv export, chrome extension, google sheets export, scraping tool, web data"
  ctaTitle="Start Extracting Data"
  ctaDescription="Point, click, and export — web scraping made simple."
/>
