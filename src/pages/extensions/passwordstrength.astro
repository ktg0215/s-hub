---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "PasswordStrength",
  subtitle: "Real-time Strength Meter",
  tagline: "See your password strength as you type — Weak, Fair, Strong, or Very Strong — with tips to improve it. Only 11KB.",
  price: "Free",
  status: "Available",
  chromeUrl: "",
  edgeUrl: "",
  category: "Wellbeing",
  lang: "EN",
  icon: "/ext-icons/PasswordStrength.png",
  rating: 0,
  reviewCount: 0,
};

const overview = "PasswordStrength injects a real-time strength meter below every password input field, on any website. As you type, a color-coded bar and label (Weak / Fair / Strong / Very Strong) update instantly. Actionable hints tell you exactly what to add — uppercase letters, numbers, or special characters — to strengthen your password before you submit.";

const features = [
  { title: "Real-Time Feedback", desc: "The strength bar and label update on every keystroke. You see your password's strength before you commit to it." },
  { title: "4-Level Scoring", desc: "Custom scoring algorithm checks length, character variety (uppercase, lowercase, numbers, symbols), and common password detection." },
  { title: "Actionable Hints", desc: "Instead of just a score, PasswordStrength tells you exactly what to add — 'Add uppercase letters' or 'Add special characters'." },
  { title: "Works Everywhere", desc: "Automatically attaches to every password field on every site, including login forms, registration pages, and settings." },
];

const targetUsers = [
  "Anyone who wants to create stronger passwords",
  "People who struggle to remember what makes a good password",
  "Security-conscious users across all skill levels",
  "Developers testing their own registration forms",
];

const screenshots: string[] = [];

const relatedProducts = [
  { name: "PrivacyGuard", category: "Wellbeing", link: "/extensions/privacyguard/", icon: "/ext-icons/PrivacyGuard.png" },
  { name: "SiteMapper", category: "Developer Tools", link: "/extensions/sitemapper/", icon: "/ext-icons/SiteMapper.png" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: extension.name,
  description: extension.tagline,
  applicationCategory: "BrowserApplication",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  seoTitle="PasswordStrength — Real-time Password Strength Meter for Chrome"
  seoDescription="See password strength as you type on any website. Weak/Fair/Strong/Very Strong indicator with actionable tips. Free, only 11KB."
  seoKeywords="password strength, password checker, security, strong password, chrome extension, real-time"
/>
