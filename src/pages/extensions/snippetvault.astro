---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "SnippetVault",
  subtitle: "Code Snippet Manager with Slash Commands",
  tagline: "Manage code snippets and insert them instantly with slash commands in any text field.",
  price: "Free",
  status: "Coming Soon",
  chromeUrl: "https://chromewebstore.google.com/detail/snippetvault/gnnmjklohcoaiheikefoifiekcnndcdi",
  category: "Developer Tools",
  lang: "EN",
  icon: "/ext-icons/SnippetVault.png",
  rating: 0,
  reviewCount: 0,
  userCount: 8,
};

const overview = "Developer-focused code snippet manager for Chrome. Save, organize, and instantly insert code snippets using slash commands (/) in any text input field on the web. Features syntax highlighting powered by Prism.js, fuzzy search with Fuse.js, and category management. All data is stored locally on your device.";

const features = [
  { title: "Slash Commands", desc: "Type '/' in any text field to search and insert snippets instantly" },
  { title: "Syntax Highlighting", desc: "Prism.js-powered code display with dark theme support" },
  { title: "Fuzzy Search", desc: "Find snippets by title, content, or category with Fuse.js" },
  { title: "Category Management", desc: "Organize snippets by language and custom categories" },
  { title: "Usage Statistics", desc: "Track most-used snippets and usage patterns" },
  { title: "Clipboard Integration", desc: "One-click copy or auto-insert into text fields" },
];

const keyboardShortcuts = [
  { key: "/", desc: "Activate slash command in any text field" },
  { key: "Ctrl+Shift+V", desc: "Open snippet manager popup" },
  { key: "Esc", desc: "Close snippet search overlay" },
];

const targetUsers = [
  "Developers who frequently reuse code patterns",
  "Technical writers using code templates",
  "Support engineers with common response snippets",
  "Anyone who types repetitive text in web forms",
];

const screenshots = [
  "/screenshots/SnippetVault/resized_1280x800_25.png",
  "/screenshots/SnippetVault/resized_1280x800_26.png",
];

const relatedProducts = [
  { name: "PromptStash", category: "Productivity", link: "/extensions/promptstash/", icon: "/ext-icons/promptstash.webp" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "SnippetVault",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/snippetvault/",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/SnippetVault/resized_1280x800_25.png",
  featureList: "Slash Commands, Syntax Highlighting, Fuzzy Search, Category Management, Usage Statistics, Clipboard Integration",
};

const faqItems = [
  { question: "Is SnippetVault free?", answer: "Yes. SnippetVault is completely free with all snippet management and slash command features included." },
  { question: "How do I install SnippetVault?", answer: "Click 'Add to Chrome' on the Chrome Web Store. After installation, save your first snippet in the popup. Then type '/' in any text field on the web to trigger the snippet picker." },
  { question: "Does SnippetVault collect my data?", answer: "No. All snippets are stored locally on your device using Chrome's storage API. No code is sent to external servers." },
  { question: "Does the slash command work on all websites?", answer: "SnippetVault's slash command works in most standard text input fields and contenteditable areas across the web, including GitHub, Notion, and Linear." },
];
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  keyboardShortcuts={keyboardShortcuts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="SnippetVault - Code Snippet Manager with Slash Commands | Chrome Extension"
  seoDescription="Developer-focused code snippet manager. Insert snippets instantly with slash commands in any text field. Syntax highlighting and fuzzy search."
  seoKeywords="code snippets, snippet manager, slash commands, developer tools, chrome extension, code templates"
/>
