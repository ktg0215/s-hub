---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "DataBridge",
  subtitle: "Visual Data Transfer",
  tagline: "Transfer data between web pages with visual element mapping. Match elements by number and transfer with one click.",
  price: "Free / Pro $6/mo or $39 lifetime",
  status: "Available",
  chromeUrl: "",
  category: "Productivity",
  lang: "Multi",
  icon: "/ext-icons/databridge.webp",
  rating: 0,
  reviewCount: 0,
  userCount: 11,
};

const overview = "DataBridge is a Chrome extension that enables visual data transfer between web pages. Select elements from a source page, match them with target fields using numbered badges, and transfer data with a single click. Perfect for data entry, form filling, and repetitive copy-paste tasks across different systems. Free plan includes 10 templates and 30 actions/month. Pro unlocks unlimited usage.";

const features = [
  { title: "Visual Element Selection", desc: "Click elements on web pages to select them. Blue badges for source, green for target - intuitive visual mapping." },
  { title: "Number-Based Matching", desc: "Elements are automatically matched by their selection order. Same number = same data transfer." },
  { title: "One-Click Transfer", desc: "Transfer all mapped data between pages with a single button click. Supports input fields, textareas, and React/Vue framework forms." },
  { title: "Template System", desc: "Save your element mappings as templates. Reload them anytime to repeat the same transfer workflow. Free plan allows up to 10 templates." },
  { title: "Notepad Mode", desc: "Collect values from multiple elements into a notepad. Copy to clipboard or edit manually. Dedicated templates for notepad workflows." },
  { title: "Smart Selector Generation", desc: "Generates robust CSS selectors using ID, name, data attributes with multiple fallback strategies for reliability." },
  { title: "Export & Import", desc: "Export your settings and templates as JSON for backup or transfer between devices. Import to restore everything." },
  { title: "Multi-Language & Dark Mode", desc: "Available in 8 languages (EN, JA, KO, ZH, FR, IT, DE, ES) with light and dark theme support." },
];

const targetUsers = [
  "Office workers transferring data between business systems",
  "E-commerce sellers copying order details across platforms",
  "Sales and support teams entering data into CRM systems",
  "Anyone doing repetitive copy-paste between web applications",
];

const screenshots = [
  "/screenshots/databridge/screenshot-01.png",
  "/screenshots/databridge/screenshot-02.png",
  "/screenshots/databridge/screenshot-03.png",
  "/screenshots/databridge/screenshot-04.png",
  "/screenshots/databridge/screenshot-05.png",
];

const relatedProducts = [
  { name: "DataPick", category: "Productivity", link: "/extensions/datapick/", icon: "/ext-icons/datapick.webp" },
  { name: "PromptStash", category: "Productivity", link: "/extensions/promptstash/", icon: "/ext-icons/promptstash.webp" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "DataBridge",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/databridge/",
  screenshot: "https://dev-tools-hub.xyz/screenshots/databridge/screenshot-01.png",
  featureList: "Visual Element Selection, Number-Based Matching, One-Click Transfer, Template System, Notepad Mode, Smart Selector Generation, Export & Import, Multi-Language & Dark Mode",
};

const faqItems = [
  { question: "Is DataBridge free?", answer: "The free plan includes 10 templates and 30 data transfer actions per month. Pro ($6/mo or $39 lifetime) unlocks unlimited templates and actions." },
  { question: "How do I install DataBridge?", answer: "Click 'Add to Chrome' on the Chrome Web Store. After installation, open any webpage, click the DataBridge icon, and follow the visual mapping guide." },
  { question: "Does DataBridge collect my data?", answer: "No. DataBridge operates entirely within your browser. No page content or personal data is sent to external servers." },
  { question: "Which websites does DataBridge work on?", answer: "DataBridge works on any standard webpage. It uses CSS selector generation to map source and target elements, so it supports virtually any form or data-entry interface." },
];
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="DataBridge - Visual Data Transfer Between Web Pages | Chrome Extension"
  seoDescription="Transfer data between web pages with visual element mapping. Match source and target elements by number, transfer with one click. Free Chrome extension."
  seoKeywords="data transfer, web automation, form filler, copy paste, chrome extension, data entry, element mapping, web data transfer"
  ogImage="/screenshots/databridge/screenshot-01.png"
  ctaTitle="Simplify Your Data Entry Workflow"
  ctaDescription="Stop copying and pasting manually. Let DataBridge handle it with visual precision."
/>
