---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "TabVault",
  subtitle: "Smart Tab Session Manager",
  tagline: "Stash tabs, quick switch sessions, and auto-recover from browser crashes. Built for developers.",
  price: "Free / Pro $5",
  status: "Available",
  category: "Developer Tools",
  lang: "EN",
  icon: "/ext-icons/TabVault.png",
  rating: 0,
  reviewCount: 0,
  userCount: 0,
};

const overview = "Developer-focused tab session manager for Chrome. Stash your current tabs with one shortcut, switch between saved sessions instantly with Quick Switcher, and never lose tabs to browser crashes again. Features automatic backups, tab group preservation, lazy loading for memory efficiency, and keyboard-driven Quick Switcher with fuzzy search.";

const features = [
  { title: "Stash (Quick Save)", desc: "Save all current tabs and close them with one shortcut. Restore anytime" },
  { title: "Quick Switcher", desc: "Ctrl+K to fuzzy-search and restore any saved session instantly" },
  { title: "Crash Recovery", desc: "Detect unexpected shutdowns and auto-suggest session restoration" },
  { title: "Auto Backup", desc: "Configurable backup intervals: 15min, 30min, 1hr, 2hr" },
  { title: "Tab Group Preservation", desc: "Save and restore tab group names, colors, and structure" },
  { title: "Lazy Loading", desc: "Load tabs on-demand to reduce memory usage" },
];

const keyboardShortcuts = [
  { key: "Ctrl+Shift+S", desc: "Stash all current tabs" },
  { key: "Ctrl+K", desc: "Open Quick Switcher" },
  { key: "Ctrl+Shift+R", desc: "Restore last stashed session" },
];

const targetUsers = [
  "Developers context-switching between multiple projects",
  "Researchers managing topic-specific tab collections",
  "Power users with 50+ tabs who need organization",
  "Anyone who has lost tabs to a browser crash",
];

const screenshots = [
  "/screenshots/TabVault/screenshot-01.png",
  "/screenshots/TabVault/screenshot-02.png",
  "/screenshots/TabVault/screenshot-03.png",
  "/screenshots/TabVault/screenshot-04.png",
  "/screenshots/TabVault/screenshot-05.png",
];

const relatedProducts = [
  { name: "SnippetVault", category: "Developer Tools", link: "/extensions/snippetvault/", icon: "/ext-icons/SnippetVault.png" },
  { name: "PromptStash", category: "Productivity", link: "/extensions/promptstash/", icon: "/ext-icons/promptstash.webp" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "TabVault",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/tabvault/",
  screenshot: "https://dev-tools-hub.xyz/screenshots/TabVault/screenshot-01.png",
  featureList: "Stash (Quick Save), Quick Switcher, Crash Recovery, Auto Backup, Tab Group Preservation, Lazy Loading",
};

const faqItems = [
  { question: "Is TabVault free?", answer: "The core tab stashing and crash recovery features are free. Pro ($5 one-time) adds unlimited saved sessions, advanced backup options, and priority support." },
  { question: "How do I install TabVault?", answer: "Click 'Add to Chrome' on the Chrome Web Store. After installation, use the keyboard shortcut to stash your current tabs instantly and switch between sessions with the Quick Switcher." },
  { question: "Does TabVault collect my data?", answer: "No. TabVault stores all session data locally in your browser. No tab URLs or session data are sent to external servers." },
  { question: "Will TabVault recover my tabs after a crash?", answer: "Yes. TabVault automatically backs up your open tabs at regular intervals. If Chrome crashes, open TabVault and restore your last saved session in one click." },
];
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  keyboardShortcuts={keyboardShortcuts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="TabVault - Smart Tab Session Manager | Chrome Extension for Developers"
  seoDescription="Stash tabs, switch sessions instantly, and auto-recover from browser crashes. Developer-focused tab session manager with Quick Switcher and tab group support."
  seoKeywords="tab manager, session manager, chrome extension, developer tools, tab groups, tab stash, crash recovery"
/>
