---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "ReadMark",
  subtitle: "Smart Reading Position Saver",
  tagline: "Never lose your place again. Continue reading exactly where you left off.",
  price: "Free",
  status: "Available",
  chromeUrl: "https://chromewebstore.google.com/detail/inejhohffndeacbihghjcobndpoejdfn",
  edgeUrl: "https://microsoftedge.microsoft.com/addons/detail/eplmdgpbmedkiiampconlmmlmjjfaoil",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/ReadMark.webp",
  rating: 0,
  reviewCount: 0,
  userCount: 25,
};

const overview = "Ever closed a tab and lost your place in a long article? ReadMark automatically saves your scroll position on every webpage, so you can always pick up right where you left off. Unlike other bookmark tools that require manual saving, ReadMark works silently in the background. Share specific passages with friends using our smart link feature, track your reading streaks, and build better reading habits. All data stays on your device.";

const features = [
  { title: "Auto-Save Positions", desc: "Automatically saves scroll position when you leave any page" },
  { title: "One-Click Restore", desc: "Return to your exact reading position instantly" },
  { title: "Smart Share Links", desc: "Generate links to specific text passages using Text Fragments" },
  { title: "Reading Streaks", desc: "Track consecutive reading days with achievement badges" },
  { title: "Cross-Device Sync", desc: "Sync bookmarks across devices via Chrome account" },
  { title: "Privacy First", desc: "All data stored locally, no external servers" },
];

const targetUsers = [
  "Researchers reading academic papers and documentation",
  "Students studying online materials and textbooks",
  "Developers consuming technical documentation",
  "Anyone who reads more than they can finish in one sitting",
];

const screenshots = [
  "/screenshots/readmark/screenshot-01.png",
  "/screenshots/readmark/screenshot-02.png",
  "/screenshots/readmark/screenshot-03.png",
  "/screenshots/readmark/screenshot-04.png",
  "/screenshots/readmark/screenshot-05.png",
];

const relatedProducts = [
  { name: "ZenRead", category: "Productivity", link: "/extensions/zenread/", icon: "/ext-icons/ZenRead.webp" },
  { name: "PromptStash", category: "Productivity", link: "/extensions/promptstash/", icon: "/ext-icons/promptstash.webp" },
  { name: "DataPick", category: "Productivity", link: "/extensions/datapick/", icon: "/ext-icons/datapick.webp" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "ReadMark",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome, Edge",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/readmark/",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/readmark/screenshot-01.png",
  featureList: "Auto-Save Positions, One-Click Restore, Smart Share Links, Reading Streaks, Cross-Device Sync, Privacy First",
};

const definition = "ReadMark is a free Chrome and Edge extension that automatically saves your scroll position on every webpage you visit. When you return to the same page — even after closing the tab or browser — it restores you to exactly where you left off, without any manual saving. All reading positions are stored locally on your device with no data sent to external servers.";

const howToSteps = [
  "Install ReadMark from the Chrome Web Store or Microsoft Edge Add-ons.",
  "Browse the web normally — ReadMark starts saving your scroll position automatically on every page.",
  "Close a tab or the browser. When you return to the same URL, ReadMark offers to restore your position.",
  "Click the ReadMark icon in your toolbar to view your saved reading positions and reading streak.",
  "Use the Smart Share Links feature to generate a link pointing to a specific passage in any article.",
];

const faqItems = [
  { question: "How is ReadMark different from browser bookmarks?", answer: "ReadMark saves your exact scroll position along with the URL, so when you return to an article you left halfway through, it restores you to precisely where you stopped. Regular bookmarks only save the URL and always open from the top." },
  { question: "Does ReadMark sync across devices?", answer: "Yes. ReadMark Pro includes cross-device sync via your Chrome account. The free version saves positions locally on your current device only." },
  { question: "How many reading positions can I save?", answer: "The free plan saves up to 10 positions. ReadMark Pro ($3.99/month) removes all limits with unlimited positions and cloud sync." },
  { question: "Does ReadMark collect my data?", answer: "No. ReadMark stores all reading positions locally on your device. No browsing data or reading history is sent to external servers." },
  { question: "Does ReadMark work on all websites?", answer: "Yes. ReadMark automatically saves your scroll position on any standard webpage. When you close and reopen the same URL, it restores you to exactly where you left off." },
];
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  definition={definition}
  howToSteps={howToSteps}
  seoTitle="ReadMark - Smart Reading Position Saver | Free Chrome Extension"
  seoDescription="Automatically saves your reading position on any webpage. Never lose your place in long articles. Free Chrome and Edge extension with cross-device sync."
  seoKeywords="reading position saver, bookmark, scroll position, chrome extension, productivity, reading tracker"
  ctaTitle="Never Lose Your Place Again"
  ctaDescription="ReadMark saves your position automatically."
/>
