---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "Japanese Font Finder",
  subtitle: "日本語フォント検索",
  tagline: "Webページ上のフォント情報を瞬時に検出。日本語フォントに完全対応。",
  price: "Free",
  status: "Available",
  chromeUrl: "https://chromewebstore.google.com/detail/ageolfjmheacenbkgiahlkhkogcnocip",
  edgeUrl: "https://microsoftedge.microsoft.com/addons/detail/bkeehmkfjgapeejjdhdkplhbpbmcpofa",
  category: "Productivity",
  lang: "JP",
  icon: "/ext-icons/japanese-font-finder.webp",
  rating: 0,
  reviewCount: 0,
  userCount: 41,
};

const overview = "Webページ上のフォント情報を瞬時に検出するChrome拡張機能です。游ゴシック、ヒラギノ、モリサワなど日本語フォントを正確に識別し、フォントサイズ、ウェイト、行間、カラーコードなど必要な情報をワンクリックで取得できます。Manifest V3対応で軽量・高速動作。";

const features = [
  { title: "フォント名の検出", desc: "日本語フォント完全対応。ホバーで即座にフォント情報を表示" },
  { title: "詳細情報の取得", desc: "フォントサイズ・ウェイト・行間・カラーコード（HEX/RGB）を表示" },
  { title: "日本語フォント特化", desc: "游ゴシック/游明朝、ヒラギノ、メイリオ、Noto Sans JPに対応" },
  { title: "Webフォントサービス検出", desc: "Google Fonts、Adobe Fonts、TypeSquare、FONTPLUSを自動検出" },
  { title: "ブックマーク機能", desc: "気に入ったフォントをお気に入り保存。検出履歴も確認可能" },
  { title: "ページ全体スキャン", desc: "ページで使用されているフォント一覧を表示" },
];

const targetUsers = [
  "Webデザイナー",
  "フロントエンドエンジニア",
  "グラフィックデザイナー",
  "タイポグラフィに興味のある方",
];

const screenshots = [
  "/screenshots/japanese-font-finder/resized_1280x800_1.png",
  "/screenshots/japanese-font-finder/resized_1280x800_2.png",
  "/screenshots/japanese-font-finder/resized_1280x800_3.png",
];

const relatedProducts = [
  { name: "ReShapic", category: "Image Tools", link: "/extensions/reshapic/", icon: "/ext-icons/reshapic.png" },
  { name: "DataPick", category: "Productivity", link: "/extensions/datapick/", icon: "/ext-icons/datapick.webp" },
];

const definition = "Japanese Font Finder is a free Chrome extension that identifies fonts on any webpage instantly, with specialized support for 150+ Japanese fonts including Yu Gothic, Hiragino Kaku Gothic ProN, Meiryo, Noto Sans JP, and Noto Serif JP. It detects the actual rendered font — not just the CSS declaration — and shows font-family, size, weight, line-height, letter-spacing, and text color in one click. All processing is 100% local with no data sent to any server.";

const howToSteps = [
  "Install Japanese Font Finder from the Chrome Web Store — it's free.",
  "Navigate to any webpage with text you want to inspect.",
  "Click the Japanese Font Finder icon in your Chrome toolbar to activate detection mode.",
  "Hover over any text element to see the font name, size, weight, and color information instantly.",
  "Click the element to copy the CSS font-family declaration to your clipboard.",
  "Use the popup panel to view your detection history or scan all fonts used on the current page.",
];

const faqItems = [
  { question: "Does it detect Japanese fonts accurately?", answer: "Yes. Japanese Font Finder supports 150+ Japanese fonts including Yu Gothic, Yu Mincho, Hiragino Kaku Gothic ProN, Meiryo, and Noto Sans JP. Unlike general-purpose tools, it resolves the actual rendered font rather than the CSS fallback list, so it correctly identifies which font the browser is using." },
  { question: "Why do other font tools show 'sans-serif' for Japanese fonts?", answer: "Most font detection tools read the CSS font-family declaration directly, which lists all fallbacks. Japanese font stacks often have 3-5 fallbacks (e.g. 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'Meiryo', sans-serif). Japanese Font Finder resolves the actual rendered font using document.fonts API, showing the font truly in use." },
  { question: "Does it work with web font services like Google Fonts?", answer: "Yes. It automatically detects fonts loaded from Google Fonts, Adobe Fonts, TypeSquare, and FONTPLUS." },
  { question: "Is my browsing data collected?", answer: "No. All font detection runs locally in your browser. No data is sent to any external server." },
  { question: "Can I export the fonts I find?", answer: "Yes. You can export your font collection as JSON or CSV — useful for design documentation and font audits across multiple pages." },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Japanese Font Finder",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome, Edge",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/japanese-font-finder/",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/japanese-font-finder/resized_1280x800_1.png",
  featureList: "Japanese Font Detection, Full CSS Info, Color Detection (HEX/RGB/HSL), Web Font Service Detection, Font Bookmarking, Page Font Scan, JSON/CSV Export",
  isAccessibleForFree: true,
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  definition={definition}
  howToSteps={howToSteps}
  seoTitle="Japanese Font Finder - Webフォント検出Chrome拡張 | 日本語フォント検索"
  seoDescription="Webページ上のフォントを瞬時に検出する無料Chrome拡張機能。游ゴシック、ヒラギノ、Noto Sans JP対応。フォントサイズ・カラーコードも取得。"
  seoKeywords="font finder, フォント検索, 日本語フォント, Chrome拡張機能, Webフォント, 游ゴシック, ヒラギノ, Noto Sans JP, フォント検出"
  ctaTitle="フォント検索を始めよう"
  ctaDescription="Webページ上のフォント情報をワンクリックで取得。"
/>
