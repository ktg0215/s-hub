---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "PasswordStrength",
  subtitle: "Inline Password Strength Meter",
  tagline: "See real-time password strength on any login or signup form — no popup needed.",
  price: "Free",
  status: "Available",
  chromeUrl: "",
  edgeUrl: "",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/PasswordStrength.png",
  rating: 0,
  reviewCount: 0,
};

const overview = "PasswordStrength adds a compact strength meter directly below any password input field, on any website. As you type, it scores your password in real time — checking length, character variety, and common patterns — and shows a colored bar with specific tips to make it stronger. There's nothing to click or configure. It works automatically on every login and signup form you visit.";

const features = [
  { title: "Instant Inline Feedback", desc: "A strength bar appears directly beneath the password field as you type. No popup to open, no button to click — feedback is immediate and in-context." },
  { title: "Smart Scoring", desc: "Checks password length, lowercase, uppercase, numbers, and special characters. Also detects 18 of the most commonly used passwords and flags them as weak immediately." },
  { title: "Actionable Hints", desc: "Instead of just a score, the meter shows up to two specific suggestions — like 'Add uppercase letters' or 'Add special characters' — so you know exactly what to improve." },
  { title: "Ultra-Lightweight", desc: "Under 12 KB with zero external requests. Pure vanilla TypeScript content script — no React, no bundling overhead, no performance impact on the page." },
  { title: "Works Everywhere", desc: "Injected on any page with a password input, including SPAs and dynamically added forms detected via MutationObserver. No manual configuration needed." },
  { title: "Privacy First", desc: "Runs entirely in your browser. No text is ever sent to any server. Your passwords are never transmitted or stored outside your local browser." },
];

const targetUsers = [
  "Anyone who wants a nudge to use stronger passwords",
  "Developers testing login and registration forms",
  "Security-conscious users who want instant feedback without a password manager",
  "Teams that want lightweight security tooling without enterprise overhead",
];

const screenshots = [
  "/screenshots/password-strength/screenshot-01.png",
  "/screenshots/password-strength/screenshot-02.png",
  "/screenshots/password-strength/screenshot-03.png",
  "/screenshots/password-strength/screenshot-04.png",
  "/screenshots/password-strength/screenshot-05.png",
];

const relatedProducts = [
  { name: "FormValidator", category: "Productivity", link: "/extensions/formvalidator/", icon: "/ext-icons/FormValidator.png" },
  { name: "PrivacyGuard", category: "Wellbeing", link: "/extensions/privacyguard/", icon: "/ext-icons/PrivacyGuard.png" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: extension.name,
  description: extension.tagline,
  applicationCategory: "BrowserApplication",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  seoTitle="PasswordStrength — Inline Password Strength Meter for Chrome"
  seoDescription="Real-time password strength meter on any login form. No popup, no setup. Scores length, variety, and flags common passwords. Free Chrome extension."
  seoKeywords="password strength, password meter, inline password checker, password security, chrome extension, login form"
/>
