---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "ZenRead",
  subtitle: "Distraction-Free Reader Mode",
  tagline: "Remove clutter and read any article in a clean, customizable reader view with text-to-speech.",
  price: "Free",
  status: "Coming Soon",
  chromeUrl: "https://chromewebstore.google.com/detail/zenread/adoiakplckmoahmiainobfpmdomnhomj",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/ZenRead.webp",
  rating: 0,
  reviewCount: 0,
  userCount: 6,
};

const overview = "Webページの記事を読みやすいリーダーモードで表示するChrome拡張機能です。広告やサイドバーを除去し、カスタマイズ可能なテーマ・フォント設定で快適な読書体験を提供します。Readability.jsベースの高精度な記事抽出で、本文のみをクリーンに表示。Web Speech APIによるテキスト読み上げ機能も搭載。";

const features = [
  { title: "Reader Mode", desc: "Readability.jsベースの高精度な記事抽出。広告・サイドバーを除去" },
  { title: "3 Themes", desc: "Light・Dark・Sepiaの3テーマで目に優しい閲覧" },
  { title: "Font Customization", desc: "フォントサイズ・ファミリー・行間・コンテンツ幅を細かく調整" },
  { title: "Text-to-Speech", desc: "Web Speech APIによる読み上げ。速度調整・言語選択対応" },
  { title: "Highlights (Pro)", desc: "5色のハイライトで重要な箇所をマーク" },
  { title: "Reading Stats (Pro)", desc: "読了記事数・累計読書時間・読書ストリークを記録" },
];

const targetUsers = [
  "長い記事を集中して読みたい方",
  "広告やサイドバーに気を取られたくない方",
  "テキスト読み上げで「ながら読書」したい方",
  "目に優しいダーク/セピアテーマで読みたい方",
];

const screenshots = [
  "/screenshots/zenread/screenshot-01.png",
  "/screenshots/zenread/screenshot-02.png",
  "/screenshots/zenread/screenshot-03.png",
  "/screenshots/zenread/screenshot-04.png",
  "/screenshots/zenread/screenshot-05.png",
];

const relatedProducts = [
  { name: "ReadMark", category: "Productivity", link: "/extensions/readmark/", icon: "/ext-icons/ReadMark.webp" },
  { name: "Shorts Killer", category: "Wellbeing", link: "/extensions/shorts-killer/", icon: "/ext-icons/shorts-killer.webp" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "ZenRead",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/zenread/",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/zenread/screenshot-01.png",
  featureList: "Reader Mode, 3 Themes, Font Customization, Text-to-Speech, Highlights, Reading Stats",
};

const faqItems = [
  { question: "Is ZenRead free?", answer: "Yes. ZenRead is completely free with all reader mode and text-to-speech features included." },
  { question: "How do I install ZenRead?", answer: "Click 'Add to Chrome' on the Chrome Web Store. After installation, navigate to any article and click the ZenRead icon to activate distraction-free reader mode." },
  { question: "Does ZenRead collect my data?", answer: "No. ZenRead processes articles locally in your browser. No reading history or content is sent to external servers." },
  { question: "Does ZenRead work on all websites?", answer: "ZenRead uses Readability.js for article extraction and works on most news sites, blogs, and long-form content pages. Some sites with heavy JavaScript may require refreshing the page first." },
];
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="ZenRead - Distraction-Free Reader Mode | Chrome Extension"
  seoDescription="Remove ads and clutter for distraction-free reading. Customizable themes, fonts, and text-to-speech. Free Chrome extension."
  seoKeywords="reader mode, distraction-free reading, text-to-speech, chrome extension, reading, ad-free reading"
/>
