---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "PageMemo",
  subtitle: "URL-Linked Sticky Notes for Chrome",
  tagline: "Stick notes directly on pages. Auto-appear when you revisit — no searching, no account.",
  price: "Freemium",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/Pagememo.png",
  rating: 0,
  reviewCount: 0,
  userCount: 6,
  chromeUrl: "https://chromewebstore.google.com/detail/pagememo/jmpmfbheoclfmceceihjpcjlabakkdde",
};

const overview = "PageMemo links notes to the exact URL you're visiting. Revisit any page and your notes appear automatically in the side panel — no search, no clipboard paste. The new Sticky Note mode pins annotations directly to page elements so they stay in context when you come back. URL matching can be set per-note: path, exact URL, or domain — so research notes for a specific Google Search Console query don't bleed into unrelated pages. All data stays on your device.";

const features = [
  { title: "Sticky Note Mode", desc: "Pin annotations to any element on the page. Still there when you come back — even after a reload" },
  { title: "URL-Linked Notes", desc: "Notes auto-appear the moment you revisit a URL. No searching, no copy-paste" },
  { title: "Smart URL Matching", desc: "Choose path, exact URL, or domain scope per note. GSC users: keep query-specific notes separate" },
  { title: "Rich Text Editor", desc: "Bold, italic, headings, bullet lists, task checkboxes, and blockquotes" },
  { title: "Category & Tags", desc: "Organize notes with custom categories and color labels. Filter from the notes list" },
  { title: "Local Only", desc: "No account, no sync. All notes stored on your device. Export to JSON or Markdown anytime" },
];

const keyboardShortcuts = [
  { key: "Ctrl+Shift+M", desc: "Open/close memo side panel" },
  { key: "Ctrl+S", desc: "Save current note" },
  { key: "Ctrl+Shift+F", desc: "Open full-text search" },
];

const targetUsers = [
  "Researchers who want notes that follow them back to a page",
  "SEO analysts using Google Search Console — keep query-specific notes separate",
  "Developers annotating documentation, GitHub issues, or Stack Overflow answers",
  "Online learners who take notes while watching course pages",
  "Privacy-conscious users who prefer local-only, no-account storage",
];

const screenshots = [
  "/screenshots/Pagememo/screenshot-01.png",
  "/screenshots/Pagememo/screenshot-02.png",
  "/screenshots/Pagememo/screenshot-03.png",
  "/screenshots/Pagememo/screenshot-04.png",
  "/screenshots/Pagememo/screenshot-05.png",
];

const relatedProducts = [
  { name: "ReadMark", category: "Productivity", link: "/extensions/readmark/", icon: "/ext-icons/ReadMark.webp" },
  { name: "SnippetVault", category: "Developer Tools", link: "/extensions/snippetvault/", icon: "/ext-icons/SnippetVault.png" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "PageMemo",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/pagememo/",
  screenshot: "https://dev-tools-hub.xyz/screenshots/Pagememo/screenshot-01.png",
  featureList: "Sticky Note Mode, URL-Linked Notes, Smart URL Matching, Rich Text Editor, Category Management, Local-Only Storage",
};

const faqItems = [
  { question: "Is PageMemo free?", answer: "PageMemo is free for up to 5 notes. Pro is $4.99/month for unlimited notes. No account required either way." },
  { question: "What is Sticky Note mode?", answer: "Sticky Note mode lets you pin an annotation directly to a specific element on the page. Unlike the side panel, the note appears on the page itself and stays anchored to that element when you return." },
  { question: "How does URL matching work?", answer: "Each note has its own matching scope: Path (matches all pages at that path), Exact URL (only this precise URL including query string), or Domain (all pages on the site). Exact URL is useful for tools like Google Search Console where each query has its own URL." },
  { question: "Does PageMemo collect my data?", answer: "No. All notes are stored locally on your device using Chrome's storage API. Nothing is synced to external servers." },
  { question: "Will my notes appear automatically when I revisit a page?", answer: "Yes. PageMemo links each note to its URL and auto-displays it in the side panel when you navigate back to that page." },
];
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  keyboardShortcuts={keyboardShortcuts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="PageMemo - Sticky Notes for Any Web Page | Chrome Extension"
  seoDescription="Stick notes directly on web pages. Notes auto-appear when you revisit the URL — no account, no sync. New: Sticky Note mode and smart URL matching. Free up to 5 notes, Pro $4.99/mo."
  seoKeywords="page notes, sticky notes chrome extension, url linked notes, web annotations, local notes, productivity, google search console notes"
/>
