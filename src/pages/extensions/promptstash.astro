---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "PromptStash",
  subtitle: "AI Prompt Manager",
  tagline: "Save prompts, use variables, and insert instantly with slash commands. Works with 19+ AI services.",
  price: "$5 One-time",
  status: "Available",
  chromeUrl: "https://chromewebstore.google.com/detail/promptstash-ai-prompt-man/ocgkponbnolpgobllplcamfobolbjbcj",
  edgeUrl: "https://microsoftedge.microsoft.com/addons/detail/cikobjnfckldmijplgppjcgipiolkfpc",
  category: "Productivity",
  lang: "EN",
  icon: "/ext-icons/promptstash.webp",
  rating: 4.9,
  reviewCount: 12,
  userCount: 41,
};

const overview = "Using multiple AI services like ChatGPT, Claude, and Gemini, do you ever find yourself thinking 'Where was that prompt?' PromptStash v2.0 lets you save your favorite prompts and instantly recall them with slash commands, variable templates, and context-aware insertions. Works with 19+ AI services.";

const features = [
  { title: "Variable Templates", desc: "Use {{variableName}} syntax to create dynamic prompts with text, dropdown, number, and date inputs" },
  { title: "Prompt Chains", desc: "Run multiple prompts in sequence — perfect for multi-step workflows like 'Requirements → Design → Code'" },
  { title: "Slash Commands", desc: "Type '/' in any AI chat to instantly search and insert your saved prompts" },
  { title: "Context Variables", desc: "Auto-insert selected text, page URL, current date/time with built-in variables" },
  { title: "19+ AI Services", desc: "Works with ChatGPT, Claude, Gemini, Perplexity, DeepSeek, Grok, Copilot and more" },
  { title: "Tag & Favorites (Pro)", desc: "Organize with custom tags and mark your most-used prompts as favorites" },
  { title: "Import/Export", desc: "Backup and restore your prompts as JSON files. Easy migration between devices" },
  { title: "Keyboard Shortcut", desc: "Press Ctrl+Shift+P (Cmd+Shift+P on Mac) to quickly access your prompts" },
];

const supportedServices = ["ChatGPT", "Claude", "Gemini", "Perplexity", "DeepSeek", "Grok", "Copilot", "Poe", "Mistral", "HuggingChat", "You.com", "Phind", "Character.AI", "Pi", "Cohere", "Notion AI", "Google AI Studio"];

const targetUsers = [
  "People using multiple AI services daily",
  "Those with frequently-used prompts",
  "Anyone looking to optimize their prompt engineering workflow",
];

const screenshots = [
  "/screenshots/promptstash/screenshot-1.png",
  "/screenshots/promptstash/screenshot-2.png",
  "/screenshots/promptstash/screenshot-3.png",
  "/screenshots/promptstash/screenshot-4.png",
  "/screenshots/promptstash/screenshot-5.png",
  "/screenshots/promptstash/screenshot-6.png",
];

const relatedProducts = [
  { name: "DataPick", category: "Productivity", link: "/extensions/datapick/", icon: "/ext-icons/datapick.webp" },
  { name: "SnippetVault", category: "Developer Tools", link: "/extensions/snippetvault/", icon: "/ext-icons/SnippetVault.png" },
  { name: "Shorts Killer", category: "Wellbeing", link: "/extensions/shorts-killer/", icon: "/ext-icons/shorts-killer.webp" },
];

const faqItems = [
  { question: "Which AI services does PromptStash support?", answer: "PromptStash works with 19+ AI services including ChatGPT, Claude, Gemini, Perplexity, DeepSeek, Grok, Copilot, Poe, Mistral, HuggingChat, and more." },
  { question: "Is PromptStash a subscription?", answer: "No. PromptStash is a one-time purchase of $5. There are no recurring fees or subscriptions." },
  { question: "How do slash commands work?", answer: "Type '/' in any supported AI chat input to open a search overlay. Start typing to filter your saved prompts, then select one to insert it instantly." },
  { question: "Can I use variables in my prompts?", answer: "Yes. Use {{variableName}} syntax to create dynamic prompts. PromptStash supports text, dropdown, number, and date variable types." },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "PromptStash",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome, Edge",
  offers: { "@type": "Offer", price: "5", priceCurrency: "USD" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: extension.rating.toString(), reviewCount: extension.reviewCount.toString() },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/promptstash",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/promptstash/screenshot-1.png",
  featureList: "Variable Templates, Prompt Chains, Slash Commands, Context Variables, 19+ AI Services, Tag & Favorites, Import/Export, Keyboard Shortcut",
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  supportedServices={supportedServices}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="PromptStash - AI Prompt Manager for ChatGPT, Claude & Gemini"
  seoDescription="Save, organize, and instantly insert AI prompts with slash commands and variables. Works with ChatGPT, Claude, Gemini and 16+ more. One-time $5."
  seoKeywords="ai prompt manager, chatgpt prompts, claude prompts, gemini prompts, prompt library, prompt templates, chrome extension, ai productivity"
  ogImage="/images/og-promptstash.webp"
  ctaTitle="Supercharge Your AI Workflow"
  ctaDescription="Get PromptStash now and never lose a great prompt again."
  productHuntUrl="https://www.producthunt.com/products/promptstash-2?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-promptstash-2"
  productHuntImage="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1055384&theme=light"
/>
