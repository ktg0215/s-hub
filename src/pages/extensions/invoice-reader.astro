---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "請求書よみとり",
  subtitle: "AI-OCR Invoice Data Extraction",
  tagline: "PDF請求書をAI-OCRで自動読み取り。金額・日付・取引先・登録番号を抽出し、CSV/Excelにエクスポート。インボイス制度対応。",
  price: "Free / Pro",
  status: "Published",
  category: "Business Tools",
  lang: "JP",
  icon: "/ext-icons/invoice-reader.png",
  rating: 0,
  reviewCount: 0,
};

const overview = "請求書よみとりは、PDF請求書をブラウザ上でAI-OCR処理し、構造化データとして抽出するChrome拡張機能です。インストールするだけですぐに使え、アカウント登録は不要。会計ソフトを導入していなくても、金額・日付・取引先名・適格請求書発行事業者登録番号を自動認識し、CSV/Excel形式でエクスポートできます。freee・弥生会計・マネーフォワードなど、お使いの会計ソフトへの取り込みにも対応。日本のインボイス制度（適格請求書等保存方式）・電子帳簿保存法に対応し、登録番号の国税庁API検証もサポートします。フリーランス・個人事業主の確定申告から、中小企業の経理業務まで、請求書の手入力作業を無料で効率化します。";

const features = [
  { title: "AI-OCR読み取り", desc: "Tesseract.jsによるクライアントサイドOCRでPDF請求書からテキストを自動抽出" },
  { title: "構造化データ抽出", desc: "金額・税額・日付・取引先・振込先情報をインテリジェントに認識・構造化" },
  { title: "インボイス制度対応", desc: "適格請求書発行事業者登録番号（T+13桁）の自動検出・国税庁API検証" },
  { title: "CSV/Excelエクスポート", desc: "抽出データをCSVまたはExcel形式で出力。会計ソフトへの取り込みに対応" },
  { title: "バッチ処理", desc: "複数の請求書PDFをまとめてアップロード・一括処理（Pro）" },
  { title: "フィールドカスタマイズ", desc: "表示・エクスポートするフィールドを自由に設定可能" },
];

const targetUsers = [
  "会計ソフトなしでExcel手入力している個人事業主に",
  "確定申告時に請求書を一気にデータ化したいフリーランスに",
  "月額SaaSは高すぎるが手入力は限界の中小企業の経理担当に",
  "複数クライアントの請求書をサクッと処理したい税理士・会計事務所に",
];

const screenshots = [
  "/screenshots/invoice-reader/screenshot-01.png",
  "/screenshots/invoice-reader/screenshot-02.png",
  "/screenshots/invoice-reader/screenshot-03.png",
  "/screenshots/invoice-reader/screenshot-04.png",
  "/screenshots/invoice-reader/screenshot-05.png",
];

const relatedProducts = [
  { name: "DataPick", category: "Productivity", link: "/extensions/datapick/", icon: "/ext-icons/datapick.webp" },
  { name: "DataBridge", category: "Productivity", link: "/extensions/databridge/", icon: "/ext-icons/databridge.webp" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Invoice Reader",
  description: "AI-OCR extracts amounts, dates, vendors & registration numbers from PDF invoices. CSV/Excel export. Japan Invoice System ready.",
  applicationCategory: "BrowserApplication",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  seoTitle="請求書よみとり - AI-OCR PDF請求書データ抽出"
  seoDescription="PDF請求書をAI-OCRで自動読み取り。金額・日付・取引先・登録番号を抽出しCSV/Excelにエクスポート。インボイス制度対応。"
  seoKeywords="請求書, OCR, PDF, インボイス制度, 適格請求書, Chrome拡張機能, 経理, 会計, invoice reader, フリーランス, 個人事業主, 確定申告, 無料, Excel変換, CSV出力, 電子帳簿保存法, 中小企業, 請求書データ化, PDF変換"
/>
