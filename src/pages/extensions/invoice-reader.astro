---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "請求書よみとり",
  subtitle: "AI-OCR Invoice Data Extraction",
  tagline: "PDF請求書をAI-OCRで自動読み取り。金額・日付・取引先・登録番号を抽出し、CSV/Excelにエクスポート。インボイス制度対応。",
  price: "Free / Pro",
  chromeUrl: "https://chromewebstore.google.com/detail/kdlmfhdnnpbiogcbajgjheobihhanpae",
  status: "Published",
  category: "Business Tools",
  lang: "JP",
  icon: "/ext-icons/invoice-reader.png",
  rating: 0,
  reviewCount: 0,
  userCount: 3,
};

const overview = "請求書よみとりは、PDF請求書をブラウザ上でAI-OCR処理し、構造化データとして抽出するChrome拡張機能です。インストールするだけですぐに使え、アカウント登録は不要。会計ソフトを導入していなくても、金額・日付・取引先名・適格請求書発行事業者登録番号を自動認識し、CSV/Excel形式でエクスポートできます。freee・弥生会計・マネーフォワードなど、お使いの会計ソフトへの取り込みにも対応。日本のインボイス制度（適格請求書等保存方式）・電子帳簿保存法（電帳法）に対応し、登録番号の国税庁API検証もサポートします。2026年10月からの仕入税額控除の経過措置変更（80%→50%）を見据え、適格請求書の正確な判定と管理が重要です。フリーランス・個人事業主の確定申告から、中小企業の経理業務まで、請求書の手入力作業を無料で効率化します。";

const features = [
  { title: "AI-OCR読み取り", desc: "Tesseract.jsによるクライアントサイドOCRでPDF請求書からテキストを自動抽出" },
  { title: "構造化データ抽出", desc: "金額・税額・日付・取引先・振込先情報をインテリジェントに認識・構造化" },
  { title: "インボイス制度対応", desc: "適格請求書発行事業者登録番号（T+13桁）の自動検出・国税庁API検証" },
  { title: "CSV/Excelエクスポート", desc: "抽出データをCSVまたはExcel形式で出力。会計ソフトへの取り込みに対応" },
  { title: "バッチ処理", desc: "複数の請求書PDFをまとめてアップロード・一括処理（Pro）" },
  { title: "フィールドカスタマイズ", desc: "表示・エクスポートするフィールドを自由に設定可能" },
];

const targetUsers = [
  "会計ソフトなしでExcel手入力している個人事業主に",
  "確定申告時に請求書を一気にデータ化したいフリーランスに",
  "月額SaaSは高すぎるが手入力は限界の中小企業の経理担当に",
  "複数クライアントの請求書をサクッと処理したい税理士・会計事務所に",
];

const screenshots = [
  "/screenshots/invoice-reader/screenshot-01.png",
  "/screenshots/invoice-reader/screenshot-02.png",
  "/screenshots/invoice-reader/screenshot-03.png",
  "/screenshots/invoice-reader/screenshot-04.png",
  "/screenshots/invoice-reader/screenshot-05.png",
];

const relatedProducts = [
  { name: "DataPick", category: "Productivity", link: "/extensions/datapick/", icon: "/ext-icons/datapick.webp" },
  { name: "DataBridge", category: "Productivity", link: "/extensions/databridge/", icon: "/ext-icons/databridge.webp" },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Invoice Reader",
  description: "AI-OCR extracts amounts, dates, vendors & registration numbers from PDF invoices. CSV/Excel export. Japan Invoice System ready.",
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/invoice-reader",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/invoice-reader/screenshot-01.png",
  featureList: "AI-OCR読み取り, 構造化データ抽出, インボイス制度対応, CSV/Excelエクスポート, バッチ処理, フィールドカスタマイズ",
};

const faqItems = [
  { question: "請求書よみとりは無料ですか？", answer: "基本機能は無料です。複数PDF一括処理などの高度な機能はPro版で利用可能です。" },
  { question: "インボイス制度に対応していますか？", answer: "はい。適格請求書発行事業者登録番号（T+13桁）の自動検出・国税庁API検証に対応しています。" },
  { question: "2026年10月のインボイス控除率変更に対応していますか？", answer: "はい。2026年10月1日から経過措置の仕入税額控除率が80%から50%に変更されます。請求書よみとりは適格請求書かどうかを自動判定し、登録番号の検証で正確な控除率の適用をサポートします。" },
  { question: "電子帳簿保存法（電帳法）に対応していますか？", answer: "はい。PDF請求書の電子データをそのまま保存・管理でき、電子帳簿保存法の電子取引データ保存要件に対応しています。抽出データのCSV/Excel出力で検索要件も満たせます。" },
  { question: "データは外部に送信されますか？", answer: "OCR処理はTesseract.jsを使用してブラウザ上で完結します。PDFデータが外部サーバーに送信されることはありません。" },
  { question: "どの会計ソフトに対応していますか？", answer: "CSV/Excel形式でエクスポートするため、freee・弥生会計・マネーフォワードなど主要な会計ソフトへの取り込みに対応しています。" },
];
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  seoTitle="請求書よみとり - AI-OCR PDF請求書データ抽出 | インボイス制度・電帳法対応 | 無料Chrome拡張機能"
  seoDescription="PDF請求書をAI-OCRで自動読み取り。金額・日付・取引先・登録番号を抽出しCSV/Excelにエクスポート。インボイス制度対応・電子帳簿保存法対応。2026年10月控除率変更にも対応の無料Chrome拡張機能。"
  seoKeywords="請求書, OCR, PDF, インボイス制度, 適格請求書, Chrome拡張機能, 経理, 会計, invoice reader, フリーランス, 個人事業主, 確定申告, 無料, Excel変換, CSV出力, 電子帳簿保存法, 電帳法, 2026年10月, 控除率変更, 仕入税額控除, 適格請求書発行事業者"
/>
