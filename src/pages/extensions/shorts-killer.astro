---
import ExtensionLayout from '../../layouts/ExtensionLayout.astro';

const extension = {
  name: "Shorts Killer",
  subtitle: "Hide YouTube Shorts",
  tagline: "Block YouTube Shorts with page-specific controls, statistics, and keyboard shortcuts",
  price: "Free",
  status: "Available",
  chromeUrl: "https://chromewebstore.google.com/detail/shorts-killer-hide-youtub/bajebpkjihldiceceompbcjgepnbhnni",
  edgeUrl: "https://microsoftedge.microsoft.com/addons/detail/eldpofblinkjefkegpjeaajmlobemhpo",
  category: "Digital Wellbeing",
  lang: "EN",
  icon: "/ext-icons/shorts-killer.webp",
  rating: 5.0,
  reviewCount: 10,
  userCount: 180,
};

const overview = "YouTube Shorts are highly addictive, and before you know it, hours have slipped away. Shorts Killer v1.1 completely removes Shorts from YouTube with page-specific controls, block statistics, and keyboard shortcuts. Take back control of your viewing experience.";

const features = [
  { title: "Hide Shorts from home feed", desc: "Remove all Shorts videos from your YouTube homepage" },
  { title: "Page-specific controls", desc: "Toggle blocking ON/OFF for Home, Search, Channel, and Video pages individually" },
  { title: "Block counter", desc: "Track how many Shorts you've blocked - see your progress in the popup" },
  { title: "Keyboard shortcut", desc: "Press Alt+Shift+S to instantly toggle blocking ON/OFF" },
  { title: "Remove Shorts tab from sidebar", desc: "Clean up your navigation by hiding the Shorts tab" },
  { title: "Auto-redirect from Shorts pages", desc: "Automatically redirect away from Shorts URLs" },
];

const targetUsers = [
  "People who want to reduce wasted time on YouTube",
  "Those who want to focus on long-form content",
  "Anyone practicing digital detox",
];

const screenshots = [
  "/screenshots/shorts-killer/ysk-01.png",
  "/screenshots/shorts-killer/ysk-02.png",
  "/screenshots/shorts-killer/ysk-03.png",
  "/screenshots/shorts-killer/ysk-04.png",
  "/screenshots/shorts-killer/ysk-05.png",
];

const relatedProducts = [
  { name: "X Detox", category: "Wellbeing", link: "/extensions/x-detox/", icon: "/ext-icons/x-detox.webp" },
  { name: "Yahoo快適モード", category: "Wellbeing", link: "/extensions/yahoo-kaiteki-mode/", icon: "/ext-icons/yahoo-kaiteki-mode.webp" },
  { name: "TVer Plus", category: "Media", link: "/extensions/tver-plus/", icon: "/ext-icons/tver-plus.webp" },
];

const definition = "Shorts Killer is a free Chrome and Edge extension that completely removes YouTube Shorts from your browsing experience. It hides Shorts from the homepage, search results, channel pages, and sidebar, and automatically redirects away from Shorts URLs — so you can focus on long-form video content without distraction.";

const howToSteps = [
  "Install Shorts Killer from the Chrome Web Store or Microsoft Edge Add-ons.",
  "Go to YouTube — Shorts will no longer appear in your Home feed immediately.",
  "Click the Shorts Killer icon in your toolbar to customize which page types to block (Home, Search, Channel, Video).",
  "Use Alt+Shift+S to quickly toggle blocking on/off with a keyboard shortcut.",
  "Check the popup to see how many Shorts you've blocked in total.",
];

const faqItems = [
  { question: "Does Shorts Killer completely remove YouTube Shorts?", answer: "Yes. Shorts Killer removes Shorts from the YouTube homepage, search results, channel pages, and sidebar. It also auto-redirects you away from Shorts URLs so you can't accidentally land on a Shorts page." },
  { question: "Can I control which pages block Shorts?", answer: "Yes. You can toggle Shorts blocking independently for Home, Search, Channel, and Video pages from the popup. This lets you, for example, keep Shorts in search results while removing them from the homepage." },
  { question: "Will it affect my regular YouTube videos?", answer: "No. Shorts Killer only removes Shorts content. Regular videos, playlists, channels, subscriptions, and YouTube Music are completely unaffected." },
  { question: "Is Shorts Killer free?", answer: "Yes, Shorts Killer is completely free with no ads, no premium tier, and no in-app purchases." },
  { question: "Does it work on Microsoft Edge?", answer: "Yes. Shorts Killer is available for both Chrome and Microsoft Edge. The same extension works identically on both browsers." },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Shorts Killer",
  description: extension.tagline,
  applicationCategory: "BrowserExtension",
  operatingSystem: "Chrome, Edge",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: extension.rating.toString(), reviewCount: extension.reviewCount.toString() },
  author: { "@type": "Organization", name: "S-Hub", url: "https://dev-tools-hub.xyz" },
  url: "https://dev-tools-hub.xyz/extensions/shorts-killer/",
  downloadUrl: extension.chromeUrl,
  screenshot: "https://dev-tools-hub.xyz/screenshots/shorts-killer/ysk-01.png",
  featureList: "Hide Shorts from home feed, Page-specific controls, Block counter, Keyboard shortcut, Remove Shorts tab from sidebar, Auto-redirect from Shorts pages",
};
---

<ExtensionLayout
  extension={extension}
  overview={overview}
  features={features}
  targetUsers={targetUsers}
  screenshots={screenshots}
  relatedProducts={relatedProducts}
  softwareSchema={softwareSchema}
  faqItems={faqItems}
  definition={definition}
  howToSteps={howToSteps}
  seoTitle="Shorts Killer - Block & Hide YouTube Shorts | Free Chrome Extension"
  seoDescription="Free Chrome & Edge extension to block YouTube Shorts completely. Page-specific controls, block counter, keyboard shortcuts. Rated 5.0 by 10+ users."
  seoKeywords="block youtube shorts, youtube shorts remover, hide youtube shorts, youtube shorts blocker, chrome extension, digital wellbeing"
  ogImage="/images/og-shorts-killer.webp"
  ctaTitle="Ready to Focus?"
  ctaDescription="Install Shorts Killer now and take back control of your YouTube experience."
  productHuntUrl="https://www.producthunt.com/products/shorts-killer?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-shorts-killer"
  productHuntImage="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1054755&theme=light"
/>
