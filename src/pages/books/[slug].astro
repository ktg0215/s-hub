---
import Layout from '../../layouts/Layout.astro';
import { books, getBook, getRelatedBooks } from '../../data/books';

export function getStaticPaths() {
  return books.map((book) => ({ params: { slug: book.slug } }));
}

const { slug } = Astro.params;
const book = getBook(slug)!;
const related = getRelatedBooks(slug);

const colorBadge: Record<string, string> = {
  sky: 'bg-sky-50 border-sky-200 text-sky-700',
  amber: 'bg-amber-50 border-amber-200 text-amber-700',
  emerald: 'bg-emerald-50 border-emerald-200 text-emerald-700',
  rose: 'bg-rose-50 border-rose-200 text-rose-700',
};
const colorDot: Record<string, string> = {
  sky: 'bg-sky-400',
  amber: 'bg-amber-400',
  emerald: 'bg-emerald-400',
  rose: 'bg-rose-400',
};
const colorAccent: Record<string, string> = {
  sky: 'border-sky-100 bg-sky-50/40',
  amber: 'border-amber-100 bg-amber-50/40',
  emerald: 'border-emerald-100 bg-emerald-50/40',
  rose: 'border-rose-100 bg-rose-50/40',
};
const seriesIndex = books.findIndex((b) => b.slug === slug) + 1;
const totalChapterWords = book.chapters.reduce((s, c) => s + c.wordCount, 0);

const bookSchema = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": book.title,
  "description": book.tagline,
  "url": `https://dev-tools-hub.xyz/books/${book.slug}/`,
  "inLanguage": "ja",
  "bookFormat": "EBook",
  "numberOfPages": Math.round(totalChapterWords / 300),
  "author": {
    "@type": "Person",
    "name": "ktg",
    "url": "https://zenn.dev/ktg"
  },
  "publisher": {
    "@type": "Organization",
    "name": "S-Hub",
    "url": "https://dev-tools-hub.xyz"
  },
  "offers": {
    "@type": "Offer",
    "price": book.price,
    "priceCurrency": "JPY",
    "availability": "https://schema.org/InStock",
    "url": book.zennUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "S-Hub", "item": "https://dev-tools-hub.xyz/" },
    { "@type": "ListItem", "position": 2, "name": "Books", "item": "https://dev-tools-hub.xyz/books/" },
    { "@type": "ListItem", "position": 3, "name": book.title, "item": `https://dev-tools-hub.xyz/books/${book.slug}/` }
  ]
};

const faqSchema = book.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": book.faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
} : null;
---

<Layout
  title={`${book.title} — S-Hub Books`}
  description={book.tagline}
  keywords={`Chrome拡張 本, 個人開発 書籍, ${book.title}, Zenn books`}
  lang="ja"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>
  <div class="max-w-4xl mx-auto px-6 py-16">

    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 font-mono text-[11px] text-zinc-400">
      <a href="/books/" class="hover:text-zinc-600 transition-colors">books</a>
      <span>/</span>
      <span class="text-zinc-500">book {seriesIndex}</span>
    </nav>

    <!-- Hero -->
    <div class="grid sm:grid-cols-[160px_1fr] gap-8 mb-14">
      <!-- Cover -->
      <div class={`h-[200px] sm:h-[216px] rounded-xl border flex items-center justify-center shrink-0 ${colorAccent[book.color]}`}>
        <div class="text-center">
          <p class="font-mono text-[11px] text-zinc-400 mb-1">Book {seriesIndex}</p>
          <p class={`font-mono text-2xl font-bold text-zinc-300`}>{seriesIndex}</p>
        </div>
      </div>

      <!-- Meta -->
      <div class="flex flex-col justify-center">
        <div class="flex flex-wrap gap-2 mb-3">
          <span class={`inline-flex items-center text-[11px] font-medium border rounded-full px-2.5 py-0.5 ${colorBadge[book.color]}`}>
            {book.priceLabel}
          </span>
          <span class="inline-flex items-center text-[11px] border border-zinc-200 text-zinc-500 rounded-full px-2.5 py-0.5">
            {book.status === 'coming-soon' ? book.releaseLabel : '公開中'}
          </span>
        </div>

        <h1 class="text-2xl font-bold text-zinc-900 leading-snug mb-2">{book.title}</h1>
        <p class="text-[14px] text-zinc-500 mb-4">{book.subtitle}</p>
        <p class="text-[13px] text-zinc-500 leading-relaxed mb-5">{book.tagline}</p>

        <div class="flex flex-wrap gap-4 text-[12px] text-zinc-400 font-mono mb-5">
          <span>約{(totalChapterWords / 1000).toFixed(1)}万字</span>
          <span>{book.chapters.length}章</span>
        </div>

        {book.status === 'coming-soon' ? (
          <div class="flex flex-wrap gap-3">
            <a
              href={book.sampleUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 border border-zinc-200 text-zinc-700 text-[13px] font-medium px-4 py-2 rounded-lg hover:border-zinc-300 hover:bg-zinc-50 transition-colors"
            >
              サンプルを読む
            </a>
            <span class="inline-flex items-center text-[12px] text-zinc-400 font-mono px-4 py-2">
              {book.releaseLabel}
            </span>
          </div>
        ) : (
          <a
            href={book.zennUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 bg-zinc-900 text-white text-[13px] font-medium px-5 py-2.5 rounded-lg hover:bg-zinc-700 transition-colors w-fit"
          >
            Zennで読む — {book.priceLabel}
          </a>
        )}
      </div>
    </div>

    <!-- Target Readers -->
    <section class="mb-12">
      <p class="font-mono text-[11px] text-zinc-400 tracking-wider uppercase mb-4">// こんな方に</p>
      <ul class="space-y-2">
        {book.targetReaders.map((reader) => (
          <li class="flex items-start gap-3">
            <span class={`w-1.5 h-1.5 rounded-full shrink-0 mt-[7px] ${colorDot[book.color]}`}></span>
            <span class="text-[14px] text-zinc-600 leading-relaxed">{reader}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Chapter List -->
    <section class="mb-12">
      <p class="font-mono text-[11px] text-zinc-400 tracking-wider uppercase mb-4">// chapters</p>
      <div class="border border-zinc-100 rounded-xl overflow-hidden divide-y divide-zinc-100">
        {book.chapters.map((ch, i) => (
          <div class="flex items-center gap-4 px-5 py-3.5 hover:bg-zinc-50/60 transition-colors">
            <span class="font-mono text-[11px] text-zinc-300 w-5 shrink-0 text-right">{i + 1}</span>
            <span class="text-[13px] text-zinc-700 flex-1 leading-snug">{ch.title}</span>
            <span class="font-mono text-[11px] text-zinc-300 shrink-0">{ch.wordCount.toLocaleString()}字</span>
          </div>
        ))}
        <div class="flex items-center gap-4 px-5 py-3 bg-zinc-50/40">
          <span class="font-mono text-[11px] text-zinc-400 w-5 shrink-0 text-right">∑</span>
          <span class="text-[12px] text-zinc-400 flex-1">合計</span>
          <span class="font-mono text-[12px] text-zinc-400 shrink-0">{totalChapterWords.toLocaleString()}字</span>
        </div>
      </div>
    </section>

    <!-- Sample CTA -->
    <section class={`mb-12 border rounded-xl p-6 ${colorAccent[book.color]}`}>
      <p class="font-mono text-[11px] text-zinc-400 tracking-wider uppercase mb-2">// sample</p>
      <p class="text-[14px] text-zinc-700 mb-4">
        購入前に無料サンプル章をお読みいただけます。文体・内容レベルをご確認ください。
      </p>
      <a
        href={book.sampleUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 border border-zinc-200 bg-white text-zinc-700 text-[13px] font-medium px-4 py-2 rounded-lg hover:border-zinc-300 transition-colors"
      >
        サンプルを Zenn で読む →
      </a>
    </section>

    <!-- FAQ -->
    <section class="mb-12">
      <p class="font-mono text-[11px] text-zinc-400 tracking-wider uppercase mb-4">// faq</p>
      <div class="divide-y divide-zinc-100 border border-zinc-100 rounded-xl overflow-hidden">
        {book.faq.map((item) => (
          <details class="group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none hover:bg-zinc-50/80 transition-colors">
              <span class="text-[14px] font-medium text-zinc-800">{item.q}</span>
              <span class="font-mono text-[11px] text-zinc-300 group-open:rotate-180 transition-transform ml-4 shrink-0">▾</span>
            </summary>
            <p class="px-5 pb-4 text-[13px] text-zinc-500 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Related Books -->
    {related.length > 0 && (
      <section class="mb-12">
        <p class="font-mono text-[11px] text-zinc-400 tracking-wider uppercase mb-4">// series の他の本</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {related.map((rel) => {
            const relIndex = books.findIndex((b) => b.slug === rel.slug) + 1;
            return (
              <a
                href={`/books/${rel.slug}/`}
                class="group border border-zinc-200 rounded-xl p-4 flex flex-col hover:border-zinc-300 hover:shadow-sm transition-all"
              >
                <div class="flex items-center justify-between mb-3">
                  <span class="font-mono text-[11px] text-zinc-400">Book {relIndex}</span>
                  <span class={`inline-flex items-center text-[11px] font-medium border rounded-full px-2 py-0.5 ${colorBadge[rel.color]}`}>
                    {rel.priceLabel}
                  </span>
                </div>
                <h3 class="text-[13px] font-semibold text-zinc-800 leading-snug mb-2 group-hover:text-zinc-600 transition-colors">
                  {rel.title}
                </h3>
                <p class="text-[11px] text-zinc-400 mt-auto font-mono">→ 詳細を見る</p>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Final CTA -->
    <div class="border border-zinc-200 rounded-xl p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <p class="text-[14px] font-medium text-zinc-800 mb-1">{book.title}</p>
        <p class="text-[13px] text-zinc-500">{book.status === 'coming-soon' ? book.releaseLabel : '公開中 · Zenn Books'}</p>
      </div>
      {book.status === 'coming-soon' ? (
        <a
          href={book.sampleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 border border-zinc-200 text-zinc-700 text-[13px] font-medium px-5 py-2.5 rounded-lg hover:border-zinc-300 hover:bg-zinc-50 transition-colors shrink-0"
        >
          サンプルを読む
        </a>
      ) : (
        <a
          href={book.zennUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-zinc-900 text-white text-[13px] font-medium px-5 py-2.5 rounded-lg hover:bg-zinc-700 transition-colors shrink-0"
        >
          Zennで読む — {book.priceLabel}
        </a>
      )}
    </div>

  </div>
</Layout>
